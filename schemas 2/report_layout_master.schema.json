{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stratosync.example/schemas/report_layout_master.schema.json",
  "title": "STRATOSYNC Report Layout Master Schema",
  "type": "object",
  "required": [
    "version",
    "kind",
    "sections"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "executive",
        "agent",
        "enterprise"
      ]
    },
    "meta": {
      "type": "object",
      "properties": {
        "industry_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "language": {
          "type": "string",
          "default": "ja"
        },
        "branding": {
          "type": "object",
          "properties": {
            "logo_path": {
              "type": "string"
            },
            "primary_name": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "blocks"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "blocks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "type"
              ],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "kpi_table",
                    "text",
                    "bullets",
                    "metric_cards",
                    "rcl_summary",
                    "chart_ref"
                  ]
                },
                "data_path": {
                  "type": "string",
                  "description": "Dot-path into integrated_case outputs, e.g. mode_outputs.mode1.metrics"
                },
                "label_namespace": {
                  "type": "string",
                  "default": "ja"
                },
                "fields": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "key"
                    ],
                    "properties": {
                      "key": {
                        "type": "string"
                      },
                      "label": {
                        "type": "string"
                      },
                      "format": {
                        "type": "string",
                        "enum": [
                          "raw",
                          "int",
                          "float1",
                          "float2",
                          "percent",
                          "yen",
                          "usd"
                        ]
                      },
                      "unit": {
                        "type": "string"
                      },
                      "description": {
                        "type": "string"
                      }
                    },
                    "additionalProperties": true
                  }
                },
                "options": {
                  "type": "object",
                  "additionalProperties": true
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}